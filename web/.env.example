# Server-side only — never exposed to the browser.
# Claude API key for AI summary-script generation.
ANTHROPIC_API_KEY=

# Google Cloud Text-to-Speech API key (optional).
# If unset, the app falls back to the browser's built-in SpeechSynthesis voices.
GOOGLE_TTS_API_KEY=

# Port the local API server listens on (vite proxies /api here).
API_PORT=8787
